# ============================================
# Eagle Vision - Environment Configuration
# ============================================

# Kafka Configuration
KAFKA_BROKER=kafka:9092
KAFKA_RAW_FRAMES_TOPIC=raw-frames
KAFKA_EQUIPMENT_EVENTS_TOPIC=equipment-events
KAFKA_ANNOTATED_FRAMES_TOPIC=annotated-frames

# TimescaleDB Configuration
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_DB=eagle_vision
POSTGRES_USER=eagle
POSTGRES_PASSWORD=eagle_vision_2024

# Frame Producer Configuration
VIDEO_DIR=/app/sample_videos
FRAME_SKIP=3
TARGET_FPS=8
FRAME_RESIZE_WIDTH=1280
FRAME_RESIZE_HEIGHT=720

# CV Processor Configuration
YOLO_MODEL=yolov8s.pt
CONFIDENCE_THRESHOLD=0.4
MOTION_THRESHOLD=2.0
STATE_DEBOUNCE_FRAMES=5
SLIDING_WINDOW_SIZE=10

# Dashboard Configuration
STREAMLIT_PORT=8501
DASHBOARD_REFRESH_INTERVAL=1
